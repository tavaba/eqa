<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="basic">

        <!-- Tên template -->
        <field
            name="id"
            type="hidden"
        />

        <field
            name="title"
            type="text"
            label="Tên template"
            description="Tên hiển thị khi chọn template trong modal gửi thông báo."
            required="true"
            maxlength="200"
            class="form-control"
        />

        <!-- Ngữ cảnh áp dụng -->
        <field
            name="context_type"
            type="list"
            label="Ngữ cảnh áp dụng"
            description="Xác định loại đối tượng nhận email. Template chỉ xuất hiện khi gửi thông báo từ đúng ngữ cảnh này."
            required="true"
            class="form-select"
        >
            <option value="">-- Chọn ngữ cảnh --</option>
            <option value="1">Môn thi</option>
            <option value="2">Kỳ thi</option>
            <option value="3">Lớp hành chính</option>
            <option value="4">Khóa học</option>
            <option value="5">Danh sách thủ công</option>
        </field>

        <!-- Trạng thái -->
        <field
            name="published"
            type="radio"
            label="Trạng thái"
            default="1"
            class="btn-group btn-group-yesno"
        >
            <option value="1">Kích hoạt</option>
            <option value="0">Ẩn</option>
        </field>

        <!-- Tiêu đề email -->
        <field
            name="subject"
            type="text"
            label="Tiêu đề email"
            description="Hỗ trợ placeholder: {learner_name}, {learner_code}, {exam_name}, {examseason_name}..."
            required="true"
            maxlength="500"
            class="form-control"
        />

        <!-- Nội dung email -->
        <!--
            filter="raw": bắt buộc để Joomla không strip HTML khi lưu.
            Mặc định Joomla dùng safehtml → loại bỏ <br/>, <table>, style=""...
            Field này chỉ hiển thị trong backend admin → rủi ro XSS được chấp nhận.
        -->
        <field
            name="body"
            type="textarea"
            label="Nội dung email (HTML)"
            description="Nội dung dạng HTML. Placeholder: {learner_name}, {learner_code}, {exam_name}, {exam_date}, {exam_time}, {room_name}, {examseason_name}."
            required="true"
            rows="15"
            class="form-control font-monospace"
            filter="raw"
        />

    </fieldset>
</form>
