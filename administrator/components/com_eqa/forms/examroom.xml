<?xml version="1.0" encoding="utf-8" ?>
<form>
    <fieldset name="exam" addfieldprefix="Kma\Component\Eqa\Administrator\Field">
        <field
                name="id"
                type="hidden"
        />
        <field
                name="room_id"
                type="room"
                required="true"
                label="COM_EQA_ROOM"
        >
            <option value="">COM_EQA_ROOM_REQUEST</option>
        </field>
        <field  name="description"
                type="textarea"
                label="COM_EQA_DESCRIPTION"
                />
        <field
                name="created_by"
                type="user"
                label="JGLOBAL_FIELD_CREATED_BY_LABEL"
                readonly="true"
        />
        <field
                name="created_at"
                type="text"
                readonly="true"
                label="JGLOBAL_FIELD_CREATED_LABEL"
        />
        <field
                name="modified_by"
                type="user"
                label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
                readonly="true"
        />
        <field
                name="modified_at"
                type="text"
                readonly="true"
                label="JGLOBAL_FIELD_MODIFIED_LABEL"
        />
    </fieldset>
</form>
