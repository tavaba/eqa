<?xml version="1.0" encoding="utf-8" ?>
<form>
    <fieldset name="exam"
              addfieldprefix="Kma\Component\Eqa\Administrator\Field"
              addruleprefix="Kma\Library\Kma\Rule">
        <field
                name="id"
                type="hidden"
        />
        <field
                name="examseason_id"
                type="examseason"
                required="true"
                label="COM_EQA_EXAMSEASON"
        />
        <field
                name="subject_id"
                type="subject"
                class="select2-basic"
                label="COM_EQA_SUBJECT"
                description="COM_EQA_SUBJECT_DESC"
                required="true"
        >
            <option value="">COM_EQA_SUBJECT_REQUEST</option>
        </field>
        <field
                name="code"
                type="text"
                label="Mã môn thi"
                description="Mặc định là mã môn học, nhưng có thể sửa lại nếu cần. Mã môn thi phải duy nhất trong một mùa thi."
                required="true"
                validate="ExamCode"
                hint="Ví dụ: TOAN1, CLC1ATATAT2"
        />
        <field
                name="name"
                type="text"
                label="COM_EQA_EXAM_NAME"
                description="Mặc định là tên môn học, nhưng có thể sửa lại nếu cần."
                required="true"
        />
        <field
                name="allowed_rooms"
                type="room"
                multiple="true"
                label="Phòng thi được phép sử dụng"
                description="Danh sách phòng được phép sử dụng khi tổ chức thi môn này.
                Giữ Ctrl (Windows) hoặc Command (Mac) để chọn nhiều phòng.
                Để trống nếu không muốn giới hạn phòng thi (tất cả các phòng đều có thể sử dụng)."
                class="select2-basic"
        >
            <option value="">-Phòng thi được phép sử dụng-</option>
        </field>
        <field  name="is_pass_fail"
                type="radio"
                required="true"
                default="1"
                label="Là môn điều kiện"
                description="Nếu là môn điều kiện thì chỉ yêu cầu HVSV phải &quot;ĐẠT&quot;,
                điểm thi không tính vào trung bình học kỳ, trung bình chung tích lũy.
                Hiện có 2 môn cụ thể: Giáo dục thể chất, Giáo dục Quốc phòng An ninh."
                class="btn-group btn-group-yesno"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field
                name="testtype"
                type="testtype"
                label="COM_EQA_TESTTYPE"
                required="true"
        >
            <option value="">COM_EQA_TESTTYPE_REQUEST</option>
        </field>
        <field
                name="duration"
                type="number"
                label="COM_EQA_TEST_DURATION"
                description="COM_EQA_TEST_DURATION_DESC"
                default="0"
                min="0"
                step="5"
        />
        <field
                name="kmonitor"
                type="number"
                label="COM_EQA_EXAM_KMONITOR"
                description="COM_EQA_EXAM_KMONITOR_DESC"
                required="true"
                default="1.0"
                min="1.0"
                step="0.1"
        />
        <field
                name="kassess"
                type="number"
                label="COM_EQA_EXAM_KASSESS"
                description="COM_EQA_EXAM_KASSESS_DESC"
                required="true"
                default="1.0"
                min="0.5"
                max="1.0"
                step="0.1"
        />
        <field
                name="status"
                type="examstatus"
                label="COM_EQA_PROGRESS"
                required="true"
        >
            <option value="">COM_EQA_PROGRESS_REQUEST</option>
        </field>
        <field
                name="usetestbank"
                type="radio"
                required="true"
                default="0"
                label="COM_EQA_USETESTBANK"
                class="btn-group btn-group-yesno"
        >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field
                name="questiondeadline"
                type="calendar"
                showtime="false"
                label="COM_EQA_EXAM_QUESTION_DEADLINE"
                translateformat="true"
        />
        <field
                name="questiondate"
                type="calendar"
                showtime="false"
                label="COM_EQA_EXAM_QUESTION_DATE"
                translateformat="true"
        />
        <field
                name="questionsender_id"
                type="employee"
                class="select2-basic"
                label="Người giao đề"
        >
            <option value="">- Người giao đề -</option>
        </field>
        <field
                name="questionauthor_id"
                type="employee"
                class="select2-basic"
                label="Người ra đề"
        >
            <option value="">- Người ra đề -</option>
        </field>
        <field
                name="nquestion"
                type="number"
                label="Số lượng đề"
                default="1"
                min="1"
                step="1"
        />
        <field
                name="created_by"
                type="user"
                label="JGLOBAL_FIELD_CREATED_BY_LABEL"
                readonly="true"
        />
        <field
                name="created_at"
                type="text"
                readonly="true"
                label="JGLOBAL_FIELD_CREATED_LABEL"
        />
        <field
                name="modified_by"
                type="user"
                label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
                readonly="true"
        />
        <field
                name="modified_at"
                type="text"
                readonly="true"
                label="JGLOBAL_FIELD_MODIFIED_LABEL"
        />
    </fieldset>
</form>
