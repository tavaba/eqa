<?xml version="1.0" encoding="utf-8" ?>
<form>
    <fieldset name="building">
        <field
                name="id"
                type="hidden"
            />

        <field
                name="code"
                type="text"
                label="COM_EQA_FORM_BUILDING_CODE_LABEL"
                required="true"
                pattern="[A-Z0-9]{2,10}"
        />
        <field
                name="description"
                type="textarea"
                label="COM_EQA_GENERAL_DESC"
        />
        <field
                name="created_by"
                type="user"
                label="JGLOBAL_FIELD_CREATED_BY_LABEL"
                readonly="true"
        />
        <field
                name="created_at"
                type="text"
                readonly="true"
                label="JGLOBAL_FIELD_CREATED_LABEL"
        />
        <field
                name="modified_by"
                type="user"
                label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
                readonly="true"
        />
        <field
                name="modified_at"
                type="text"
                readonly="true"
                label="JGLOBAL_FIELD_MODIFIED_LABEL"
        />
    </fieldset>
</form>