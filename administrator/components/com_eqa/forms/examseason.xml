<?xml version="1.0" encoding="utf-8" ?>
<!--
   Trong form này có sử dụng custom form field, cụ thể là "DegreeField" cho trường 'degree'
   Vì thế, trong thẻ FIELDSET cần có thuộc tính 'addfieldprefix' tương ứng
   Tham khảo từ:  https://www.abdulwaheed.pk/en/blog/41-information-technology/44-joomla/335-how-to-create-custom-form-field-for-custom-component-joomla-4.html
-->
<form>

    <!-- ================================================================== -->
    <!-- Fieldset 1: Thông tin cơ bản                                        -->
    <!-- ================================================================== -->
    <fieldset name="examseason" label="Thông tin cơ bản" addfieldprefix="Kma\Component\Eqa\Administrator\Field">

        <field
                name="id"
                type="hidden"
        />

        <field
                name="academicyear"
                type="academicyear"
                label="COM_EQA_ACADEMICYEAR"
                required="true"
        >
            <option value="">COM_EQA_ACADEMICYEAR_REQUEST</option>
        </field>

        <field
                name="term"
                type="term"
                label="COM_EQA_TERM"
                required="true"
        />

        <field
                name="type"
                type="examtype"
                required="true"
                label="COM_EQA_FORM_EXAMSEASON_TYPE_LABEL"
        >
            <option value="">COM_EQA_FORM_EXAMSEASON_TYPE_MSG</option>
        </field>

        <field
                name="attempt"
                type="integer"
                first="1"
                last="2"
                step="1"
                label="COM_EQA_FORM_EXAMSEASON_ATTEMPT_LABEL"
                description="COM_EQA_EXAMSEASON_ATTEMPT_DESC"
                required="true"
        />

        <field
                name="name"
                type="text"
                label="COM_EQA_FORM_EXAMSEASON_NAME_LABEL"
                description="COM_EQA_FORM_EXAMSEASON_NAME_DESC"
                required="true"
                hint="Thi KTHP. Hệ ĐHP. Học kỳ 2. Lần 1. Đợt 2"
        />

        <field
                name="start"
                type="calendar"
                showtime="false"
                label="COM_EQA_FORM_EXAMSEASON_DATEBEGIN_LABEL"
                description="COM_EQA_FORM_EXAMSEASON_DATEBEGIN_DESC"
                required="true"
                singleheader="true"
                translateformat="true"
        />

        <field
                name="finish"
                type="calendar"
                showtime="false"
                label="COM_EQA_FORM_EXAMSEASON_DATEEND_LABEL"
                description="COM_EQA_FORM_EXAMSEASON_DATEEND_DESC"
                required="true"
                singleheader="true"
                translateformat="true"
        />

        <field
                name="description"
                type="textarea"
                label="COM_EQA_GENERAL_DESC"
        />

        <field
                name="statistic"
                type="subform"
                formsource="administrator/components/com_eqa/forms/examseason_statistic.xml"
                label="COM_EQA_FORM_EXAMSEASON_STATISTIC_LABEL"
                description="COM_EQA_FORM_EXAMSEASON_STATISTIC_DESC"
        />

        <field
                name="created_by"
                type="user"
                label="JGLOBAL_FIELD_CREATED_BY_LABEL"
                readonly="true"
        />

        <field
                name="created_at"
                type="text"
                readonly="true"
                label="JGLOBAL_FIELD_CREATED_LABEL"
        />

        <field
                name="modified_by"
                type="user"
                label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
                readonly="true"
        />

        <field
                name="modified_at"
                type="text"
                readonly="true"
                label="JGLOBAL_FIELD_MODIFIED_LABEL"
        />

    </fieldset>

    <!-- ================================================================== -->
    <!-- Fieldset 2: Phúc khảo &amp; Thanh toán                             -->
    <!-- ================================================================== -->
    <fieldset name="ppaa" label="Phúc khảo &amp; Thanh toán" addfieldprefix="Kma\Component\Eqa\Administrator\Field">

        <field
                name="ppaa_req_enabled"
                type="list"
                required="true"
                default="0"
                label="Mở quyền phúc khảo"
                description="Cho phép sinh viên gửi yêu cầu phúc khảo/đính chính qua cổng thông tin"
        >
            <option value="1">JYES</option>
            <option value="0">JNO</option>
        </field>

        <field
                name="ppaa_req_deadline"
                type="calendar"
                showtime="true"
                label="Thời hạn phúc khảo"
                description="Để trống nếu không giới hạn thời gian"
                format="%Y-%m-%d %H:%M:%S"
                required="false"
                singleheader="false"
                translateformat="true"
        />

        <field
                name="bank_napas_code"
                type="banknapascode"
                required="false"
                default=""
                label="Ngân hàng thu phí phúc khảo"
                description="Chọn ngân hàng nhận thanh toán phí phúc khảo (dùng để tạo mã VietQR)"
                class="select2-basic"
        />

        <field
                name="bank_account_number"
                type="text"
                required="false"
                maxlength="50"
                label="Số tài khoản"
                description="Số tài khoản ngân hàng nhận phí phúc khảo. Kiểm tra cẩn thận — phần mềm không thể xác minh tính chính xác."
        />

        <field
                name="bank_account_owner"
                type="text"
                required="false"
                maxlength="255"
                label="Chủ tài khoản"
                description="Tên chủ tài khoản (hiển thị cho sinh viên khi quét mã QR)"
        />

    </fieldset>

</form>
