<?xml version="1.0" encoding="utf-8" ?>
<form>
    <fieldset name="examsession" addfieldprefix="Kma\Component\Eqa\Administrator\Field">
        <field  name="id"
                type="hidden"
                />

        <!--
            Trường UI để chọn loại ca thi.
            Không lưu vào DB — chỉ dùng để điều khiển hiển thị có điều kiện
            của examseason_id (loại 1) và assessment_id (loại 2).
            Default = 1 (Thi KTHP / tốt nghiệp).
        -->
        <field  name="session_type"
                type="list"
                default="1"
                required="true"
                label="Loại ca thi"
        >
            <option value="1">Thi KTHP / thi tốt nghiệp</option>
            <option value="2">Thi sát hạch</option>
        </field>

        <!--
            Kỳ thi (examseason): chỉ hiển thị khi loại ca thi = 1.
            Không còn required ở mức XML; validation thực hiện trong Model.
        -->
        <field  name="examseason_id"
                type="examseason"
                class="select2-basic"
                label="COM_EQA_EXAMSEASON"
                required="false"
                showon="session_type:1"
        />

        <!--
            Kỳ sát hạch (assessment): chỉ hiển thị khi loại ca thi = 2.
        -->
        <field  name="assessment_id"
                type="sql"
                class="select2-basic"
                label="Kỳ sát hạch"
                required="false"
                showon="session_type:2"
                query="SELECT id, title FROM #__eqa_assessments WHERE published = 1 ORDER BY title"
                key_field="id"
                value_field="title"
        >
            <option value="">- Chọn kỳ sát hạch -</option>
        </field>

        <field  name="start"
                type="calendar"
                showtime="true"
                format="%Y-%m-%d %H:%M"
                required="true"
                label="COM_EQA_EXAMSESSION_START_DATETIME"
                translateformat="true"
        />
        <field  name="name"
                type="text"
                required="true"
                label="COM_EQA_EXAMSESSION_NAME"
                description="COM_EQA_EXAMSESSION_NAME_DESC"
                />
        <field  name="flexible"
                type="radio"
                required="true"
                default="0"
                label="COM_EQA_EXAMSESSION_FLEXIBLE"
                description="COM_EQA_FLEXIBLE_EXAMSESSION_DESC"
                class="btn-group btn-group-yesno"
            >
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>
        <field  name="monitor_ids"
                type="employee"
                multiple="true"
                class="select2-basic"
                label="COM_EQA_EXAMSESSION_MONITORS"
        >
            <option value="" disable="true">COM_EQA_EXAMSESSION_MONITORS_REQUEST</option>
        </field>
        <field  name="examiner_ids"
                type="employee"
                multiple="true"
                class="select2-basic"
                label="COM_EQA_EXAMSESSION_EXAMINERS"
        >
            <option value="" disable="true">COM_EQA_EXAMSESSION_EXAMINERS_REQUEST</option>
        </field>
        <field  name="description"
                type="textarea"
                label="COM_EQA_DESCRIPTION"
                />
    </fieldset>
</form>
