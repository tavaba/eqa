<?xml version="1.0" encoding="utf-8" ?>
<form>
    <fieldset name="academicyear">
        <field
                name="id"
                type="hidden"
            />

        <field
                name="code"
                type="text"
                required="true"
                pattern="[0-9]{4}-[0-9]{4}"
                label="COM_EQA_FORM_ACADEMICYEAR_CODE_LABEL"
                description="COM_EQA_FORM_ACADEMICYEAR_CODE_DESC"
        />
        <field
                name="description"
                type="textarea"
                label="COM_EQA_GENERAL_DESC"
        />
        <field name="default" type="list" readonly="true"  required="true" label="COM_EQA_GENERAL_DEFAULT" default="0">
            <option value="1">JYES</option>
            <option value="0">JNO</option>
        </field>
        <field name="published" type="list" readonly="true"  required="true" label="JSTATUS" default="1">
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
        </field>
        <field
                name="created_by"
                type="user"
                label="JGLOBAL_FIELD_CREATED_BY_LABEL"
                readonly="true"
        />
        <field
                name="created_at"
                type="text"
                readonly="true"
                label="JGLOBAL_FIELD_CREATED_LABEL"
        />
        <field
                name="modified_by"
                type="user"
                label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
                readonly="true"
        />
        <field
                name="modified_at"
                type="text"
                readonly="true"
                label="JGLOBAL_FIELD_MODIFIED_LABEL"
        />
    </fieldset>
</form>