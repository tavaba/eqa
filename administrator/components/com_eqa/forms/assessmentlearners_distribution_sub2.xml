<?xml version="1.0" encoding="utf-8" ?>
<!-- Subform cấp 2: một phòng vật lý trong ca thi -->
<form>
    <field  name="room_id"
            type="room"
            label="Phòng vật lý"
            required="true"
    >
        <option value="">-- Chọn phòng --</option>
    </field>

    <field  name="nexaminee"
            type="number"
            min="1"
            max="2000"
            label="Số thí sinh"
            onchange="updateSum('nexaminee\$','jform_count_distributed')"
    />
</form>
