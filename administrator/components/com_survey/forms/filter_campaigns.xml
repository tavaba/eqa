<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            label="JSEARCH_FILTER"
        />
        <field
                name="is_over"
                type="list"
                label="Quá hạn"
                default=""
                onchange="this.form.submit();"
        >
            <option value="">- Hạn khảo sát -</option>
            <option value="0">Đang diễn ra</option>
            <option value="1">Đã qua</option>
        </field>
        <field
            name="created_by"
            type="user"
            label="Người tạo"
            onchange="this.form.submit();"
        />
        <field
                name="state"
                type="status"
                label="JSTATUS"
                onchange="this.form.submit();"
        >
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>
    </fields>
    <fields name="list">
        <!-- This hidden field is required for the ordering feature to work -->
        <field
                name="fullordering"
                type="hidden"
                value="null null"
        />
        <field
                name="limit"
                type="limitbox"
                label="JGLOBAL_LIST_LIMIT"
                onchange="this.form.submit();" />
    </fields>
</form>