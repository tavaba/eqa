<?xml version="1.0" encoding="utf-8" ?>
<form>
    <fields name="filter" addfieldprefix="Kma\Component\Survey\Administrator\Field">
        <field
                name="search"
                type="text"
                label="JSEARCH_FILTER"
                hint="JSEARCH_FILTER"
                class="js-stools-search-string"
        />
        <field
                name="user_id"
                type="user"
                label="Actor"
                class="select2-basic"
                onchange="this.form.submit();"
        >
            <option value="">- Actor -</option>
        </field>
        <field
                name="action"
                type="logaction"
                label="Action"
                default=""
                onchange="this.form.submit();"
        >
            <option value="">- Action -</option>
        </field>
        <field
                name="entity_type"
                type="logitem"
                label="Entity"
                default=""
                onchange="this.form.submit();"
        >
            <option value="">- Item type -</option>
        </field>
        <field
                name="result"
                type="result"
                label="Result"
                default=""
                onchange="this.form.submit();"
        >
            <option value="">- Result -</option>
        </field>
    </fields>
    <fields name="list">
        <!-- This hidden field is required for the ordering feature to work -->
        <field
                name="fullordering"
                type="hidden"
                value="null null"
        />
        <field
                name="limit"
                type="limitbox"
                label="JGLOBAL_LIST_LIMIT"
                onchange="this.form.submit();" />
    </fields>

</form>