<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="basic" addfieldprefix="Kma\Component\Survey\Administrator\Field">
        <field
                name="id"
                type="hidden"
        />

        <field
                name="title"
                type="text"
                label="Tên gọi"
                description="Nên đặt tên ngắn gọn để tiện cho việc hiển thị sau này.
                               Nếu cần diễn giải chi tiết thì đưa vào phần mô tả dưới đây"
                required="true"
                validate="assetName"
                addruleprefix="Kma\Component\Survey\Administrator\Rule"
        />
        <field
                name="description"
                type="textarea"
                label="Mô tả chi tiết"
        />

        <field
                name="bg_color"
                type="color"
                label="Màu nền"
                description="Được sử dụng khi hiển thị thông tin về Form trong list view"
                required="true"
        />

        <field
                name="published"
                type="radio"
                default="1"
                label="Kích hoạt"
                class="btn-group btn-group-yesno"
        >
        <option value="0">JNO</option>
        <option value="1">JYES</option>
        </field>
    </fieldset>

    <fieldset name="metadata">
        <field
                name="created"
                type="calendar"
                label="JGLOBAL_FIELD_CREATED_LABEL"
                format="%Y-%m-%d %H:%M:%S"
                readonly="true"
        />

        <field
                name="created_by"
                type="user"
                label="JGLOBAL_FIELD_CREATED_BY_LABEL"
                readonly="true"
        />

        <field
                name="modified"
                type="calendar"
                class="readonly"
                label="JGLOBAL_FIELD_MODIFIED_LABEL"
                readonly="true"
                format="%Y-%m-%d %H:%M:%S"
        />

        <field
                name="modified_by"
                type="user"
                class="readonly"
                label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
                readonly="true"
        />
    </fieldset>
</form>