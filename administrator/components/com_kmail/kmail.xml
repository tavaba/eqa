<?xml version="1.0" encoding="UTF-8" ?>
<extension type="component" method="upgrade">
    <name>COM_KMAIL</name>
	<version>1.0.0</version>
    <author>Nguyễn Tuấn Anh</author>
    <creationDate>2026-04-03</creationDate>
    <description>COM_KMAIL_DESC</description>
	
	<namespace path="src/">Kma\Component\Kmail</namespace>
	<scriptfile>script.php</scriptfile>

	<install>
		<sql>
			<file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
		</sql>
	</install>	
	<uninstall>
		<sql>
			<file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
		</sql>
	</uninstall>	
	<update>
		<schemas>
			<schemapath type="mysql">sql/updates/mysql</schemapath>
		</schemas>
	</update>	
	
    <!-- Front end -->
    <files folder="site">
		<folder>forms</folder>
		<folder>language</folder>
		<folder>src</folder>
		<folder>tmpl</folder>
    </files>

    <!-- Back end -->
    <administration>
		<menu link="option=com_kmail">COM_KMAIL</menu>
		<submenu>
			<menu view="templates">COM_KMAIL_MENU_TEMPLATES_TITLE</menu>
			<menu view="campaigns">COM_KMAIL_MENU_CAMPAIGNS_TITLE</menu>
			<menu view="logs">COM_KMAIL_MENU_LOGS_TITLE</menu>
		</submenu>
        <files folder="admin">
			<folder>forms</folder>
			<folder>language</folder>
			<folder>services</folder>
			<folder>sql</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
			<filename>access.xml</filename>
			<filename>config.xml</filename>
        </files>
    </administration>

	<!-- Media -->
	<media folder="media" destination="com_kmail">
		<filename>joomla.asset.json</filename>
		<folder>js</folder>
		<folder>images</folder>
		<folder>css</folder>
	</media>
</extension>